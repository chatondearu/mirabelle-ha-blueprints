# Reproducible toolchain via Nix (see flake.nix).
# Requires: nix (flakes), direnv, and nix-direnv for fast reloads.
#
#   direnv allow
#   pnpm install

if ! has nix_direnv; then
  source_url "https://github.com/nix-community/nix-direnv/raw/master/direnvrc" "sha256-MJx9nGHqA7DwuE2d0OwBu3RPt3XHDHBiO3YVXp3D3m8="
fi

use flake

# Rebuild venv when test requirements change (flake shellHook also checks this).
watch_file requirements-test.txt
