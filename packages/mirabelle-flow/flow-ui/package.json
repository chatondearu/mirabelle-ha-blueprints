{
  "name": "@mirabelle/flow-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:ha": "vue-tsc --noEmit && vite build --mode ha && node scripts/copy-to-ha.mjs",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@mirabelle/flow-core": "workspace:*",
    "@mirabelle/flow-shared": "workspace:*",
    "@vue-flow/core": "^1.48.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "home-assistant-js-websocket": "^9.4.0",
    "pinia": "^3.0.1",
    "reka-ui": "^2.1.1",
    "uno-variations": "^0.1.0",
    "vue": "^3.5.13",
    "yaml": "^2.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.35",
    "@unocss/preset-icons": "^66.0.0",
    "@unocss/preset-uno": "^66.0.0",
    "@unocss/reset": "^66.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.9.3",
    "unocss": "^66.0.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.5",
    "vue-tsc": "^2.2.4"
  }
}
