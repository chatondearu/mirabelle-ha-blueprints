export default "blueprint:\n  homeassistant:\n    min_version: 2025.5.3\n  name: \"[CDA] 🛋️ Create Living Area Lighting Helpers\"\n  description: >\n    Create input_select and input_boolean dashboard helpers for Living Area\n    Adaptive Lighting. Writes a package file and reloads Home Assistant core\n    configuration. Requires the shell_command documented in\n    docs/living-area-adaptive-lighting.md.\n  domain: script\n  source_url: https://github.com/chatondearu/mirabelle-ha-blueprints/blob/main/blueprints/scripts/create-living-area-lighting-helpers.yaml\n  input:\n    helper_slug:\n      name: Helper Slug\n      description: >\n        Base slug used for helper entity ids: input_select.{slug}_mode and\n        input_boolean.{slug}_hold.\n      default: living_area_lighting\n      selector:\n        text: {}\n    mode_helper_name:\n      name: Mode Helper Name\n      description: Friendly name for the mode input_select helper.\n      default: Living Area Lighting Mode\n      selector:\n        text: {}\n    hold_helper_name:\n      name: Hold Helper Name\n      description: Friendly name for the hold input_boolean helper.\n      default: Living Area Lighting Hold\n      selector:\n        text: {}\n    package_filename:\n      name: Package Filename\n      description: >\n        Filename written under /config/packages/. Leave default unless you run\n        multiple instances with different slugs.\n      default: cda_living_area_lighting_helpers.yaml\n      selector:\n        text: {}\n\nscript:\n  mode: single\n  sequence:\n    - variables:\n        helper_slug_value: !input helper_slug\n        mode_helper_name_value: !input mode_helper_name\n        hold_helper_name_value: !input hold_helper_name\n        package_filename_value: !input package_filename\n        slug: >\n          {{ helper_slug_value\n             | regex_replace('[^a-zA-Z0-9_]+', '_')\n             | lower\n             | regex_replace('^_+|_+$', '') }}\n        mode_entity: \"input_select.{{ slug }}_mode\"\n        hold_entity: \"input_boolean.{{ slug }}_hold\"\n        mode_exists: \"{{ states(mode_entity) not in ['unknown', 'unavailable', ''] }}\"\n        hold_exists: \"{{ states(hold_entity) not in ['unknown', 'unavailable', ''] }}\"\n        package_filename_resolved: \"{{ package_filename_value }}\"\n        package_b64: >\n          {% set pkg -%}\n          # Generated by [CDA] Living Area Lighting helper setup\n          input_select:\n            {{ slug }}_mode:\n              name: {{ mode_helper_name_value }}\n              options:\n                - auto\n                - day\n                - night\n                - off\n              initial: auto\n              icon: mdi:lightbulb-auto\n          input_boolean:\n            {{ slug }}_hold:\n              name: {{ hold_helper_name_value }}\n              initial: false\n              icon: mdi:hand-back-right-off\n          {%- endset %}\n          {{ pkg | b64encode }}\n    - if:\n        - condition: template\n          value_template: \"{{ mode_exists and hold_exists }}\"\n      then:\n        - stop: Living area lighting helpers already exist\n      else:\n        - service: shell_command.cda_write_living_area_lighting_helper_package\n          data:\n            package_filename: \"{{ package_filename_resolved | string }}\"\n            content_b64: \"{{ package_b64 | string }}\"\n          continue_on_error: true\n        - service: homeassistant.reload_core_config\n          continue_on_error: true\n        - delay:\n            seconds: 5\n        - variables:\n            mode_exists_after: \"{{ states(mode_entity) not in ['unknown', 'unavailable', ''] }}\"\n            hold_exists_after: \"{{ states(hold_entity) not in ['unknown', 'unavailable', ''] }}\"\n        - if:\n            - condition: template\n              value_template: \"{{ mode_exists_after and hold_exists_after }}\"\n          then:\n            - service: persistent_notification.create\n              data:\n                title: \"[CDA] Living Area Lighting Helpers\"\n                message: >\n                  Created {{ mode_entity }} and {{ hold_entity }}.\n                  Add them to your dashboard if needed.\n          else:\n            - service: persistent_notification.create\n              data:\n                title: \"[CDA] Living Area Lighting Helpers\"\n                message: >\n                  Automatic helper creation failed. Add shell_command\n                  cda_write_living_area_lighting_helper_package to configuration.yaml\n                  (see docs/living-area-adaptive-lighting.md), or create helpers manually:\n                  {{ mode_entity }} (options: auto, day, night, off) and {{ hold_entity }}.\n"